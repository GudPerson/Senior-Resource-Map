# Local development can keep the default relative /api base because Vite proxies
# requests to the local API server.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_API_URL=/api

# For Cloudflare Pages production deploys, export VITE_API_URL in the shell
# before running npm run deploy:client, for example:
# export VITE_API_URL="https://senior-resource-map-api.<subdomain>.workers.dev/api"
